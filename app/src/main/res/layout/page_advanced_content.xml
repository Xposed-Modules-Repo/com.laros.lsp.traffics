<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Traffic.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/title_self_check"
                android:textColor="@color/on_background"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/desc_self_check"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/selfCheckRefreshButton"
                style="@style/Widget.Traffic.ButtonOutline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_refresh_self_check" />

            <TextView
                android:id="@+id/selfCheckPermissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/self_check_permissions_pending"
                android:textColor="@color/on_background"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/selfCheckWifi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/self_check_wifi_pending"
                android:textColor="@color/on_background"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/selfCheckSlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/self_check_slot_pending"
                android:textColor="@color/on_background"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/selfCheckEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/self_check_enabled_pending"
                android:textColor="@color/on_background"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/selfCheckPowerMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/self_check_power_mode_pending"
                android:textColor="@color/on_background"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/selfCheckRules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/self_check_rules_pending"
                android:textColor="@color/on_background"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/selfCheckRoot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/self_check_root_pending"
                android:textColor="@color/on_background"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/selfCheckLastSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/self_check_last_switch_pending"
                android:textColor="@color/on_background"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Traffic.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/title_power_mode"
                android:textColor="@color/on_background"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/desc_power_mode"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/powerModeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/powerModeSave"
                    style="@style/Widget.Traffic.ButtonOutline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_mode_powersave" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/powerModePersistent"
                    style="@style/Widget.Traffic.ButtonOutline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/btn_mode_persistent" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Traffic.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/title_raw_json"
                android:textColor="@color/on_background"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/desc_raw_json"
                android:textColor="@color/muted"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/noWifiImmediateSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/title_no_wifi_immediate"
                android:textColor="@color/on_background" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/desc_no_wifi_immediate"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/title_no_wifi_target"
                android:textColor="@color/on_background"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/desc_no_wifi_target"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/noWifiSlotGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/noWifiSlotOff"
                    style="@style/Widget.Traffic.ButtonOutline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/btn_no_wifi_off" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/noWifiSlotSim1"
                    style="@style/Widget.Traffic.ButtonOutline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/btn_no_wifi_sim1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/noWifiSlotSim2"
                    style="@style/Widget.Traffic.ButtonOutline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/btn_no_wifi_sim2" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/exportLogsButton"
                style="@style/Widget.Traffic.ButtonOutline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_export_logs" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Traffic.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/hint_config_json_short"
                app:boxBackgroundMode="outline">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/configEditor"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:focusableInTouchMode="true"
                    android:cursorVisible="true"
                    android:longClickable="true"
                    android:scrollbarStyle="insideInset"
                    android:overScrollMode="ifContentScrolls"
                    android:nestedScrollingEnabled="true"
                    android:scrollbars="vertical"
                    android:textColor="@color/on_background"
                    android:textColorHint="@color/muted"
                    android:textIsSelectable="true"
                    android:typeface="monospace" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveButton"
                style="@style/Widget.Traffic.ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_save" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</merge>
